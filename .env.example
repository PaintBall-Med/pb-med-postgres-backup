# PostgreSQL (Railway private network recommended)
DATABASE_URL=postgresql://user:pass@postgres.railway.internal:5432/railway

# S3 / Railway Bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=https://storage.railway.app

# Service config
MODE=server
SECRET_TOKEN=
PORT=3000
CRON_SCHEDULE=0 7 * * *

# Backup config
BACKUP_FILE_PREFIX=pb-med-prod
BUCKET_SUBFOLDER=postgres/
BACKUP_RETENTION_DAYS=30

# Alpine private networking (required for Railway internal DNS)
ENABLE_ALPINE_PRIVATE_NETWORKING=true
